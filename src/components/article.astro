---
import Author from './author.astro';
import Content from './content.astro';
import Html from './html.astro';

const { frontmatter } = Astro.props;
---
<Html title={frontmatter.title} metaImage={frontmatter.hero}>
	{ frontmatter.hero !== undefined && (
		<a href={frontmatter.hero} target="_blank"><div id="hero">
			<div id="hero-image">
				<img src={frontmatter.hero} alt={frontmatter.title}/>
			</div>
		</div></a>
		<style>
			/* # Hero image styles */
			div#hero {
				/* Centre vertically */
				align-items: center;
				display: flex;
				max-height: 384px;
				overflow: hidden;
			}
			div#hero-image {
				width: 100%;
			}
			div#hero img {
				transition: transform 0.325s ease;
				width: 100%;
			}
			/* TODO: Do not transform hero if on a mobile device */
			div#hero:hover img {
				transform: scale(1.4);
			}
		</style>
		<script>
			/**
			 * Animate hero image on mouse hover. Allows user to zoom into whatever they are hovering over.
			 */
			// TODO: Improve calculation so all parts of hero image are visible on hover
			const hero = document.getElementById('hero');
			const heroImg = document.getElementById('hero-image');
			const img = heroImg!.querySelector('img');
			document.addEventListener('mousemove', (event) => {
				const heroRect = hero!.getBoundingClientRect();
				const mouseX = event.clientX - heroRect.left;
				const mouseY = event.clientY - heroRect.top;
				const heroPctX = Math.max(0, Math.min(mouseX, heroRect.width)) / heroRect.width;
				const heroPctY = Math.max(0, Math.min(mouseY, heroRect.height)) / heroRect.height;
				const heroImgRect = heroImg!.getBoundingClientRect();
				const heroImgX = heroImgRect.width * heroPctX;
  			const heroImgY = heroImgRect.height * heroPctY;
				img!.style["transform-origin"] = `${heroImgX}px ${heroImgY}px`;
			});
		</script>
	) }
	<Content>
		<h1>{frontmatter.title}</h1>
		{ frontmatter.link !== undefined && (
			<p><a href={frontmatter.link.url}>{frontmatter.link.text || frontmatter.link.url}</a></p>
		) }
		{ frontmatter.cutout !== undefined && (
			<img id="cutout" src={frontmatter.cutout}/>
			<style>
				img#cutout {
					float: right;
					margin: 0px 0px 6px 6px;
					width: 192px;
					/*
					TODO: Shrink cutout if screen is too small
					@media screen and (max-width: var(--breakpoint-medium)) {
						width: 128px;
					}
					*/
				}
			</style>
		) }
		<slot/>
		{ frontmatter.author !== undefined && (
				<Author name={frontmatter.author} coauthors={frontmatter.coauthors}/>
		) }
	</Content>
</Html>
